GROQ_API_KEY=your_groq_api_key_here
# llama-3.3-70b-versatile = detailed answers (slower). For speed: llama-3.1-8b-instant
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2560
MAX_CHAT_HISTORY=10

KB_ENABLED=true
KB_TOP_K=12
KB_RETRIEVE_POOL=24
KB_RERANK_POOL=18
KB_RERANK_ENABLED=true
# Higher retrieval quality (slower). For faster CPU inference: cross-encoder/ms-marco-MiniLM-L-6-v2
KB_RERANK_MODEL=BAAI/bge-reranker-base
KB_RERANK_MAX_CHARS=768
KB_RERANK_BATCH_SIZE=32
MAX_KB_CONTEXT_CHARS=20000
KB_CHUNK_SIZE=800
KB_CHUNK_MIN_CHARS=50
KB_CHUNK_FILTER_ENABLED=true

# Scrape settings (CLI / POST /kb/ingest/external with no_scrape=false)
KB_SEED_URLS=
KB_MAX_PDFS=0
KB_SCRAPE_DELAY_SEC=0.8
KB_SCRAPE_MAX_DEPTH=2
KB_SCRAPE_MAX_PAGES=40
KB_SCRAPE_PRODUCT_PAGES=true
KB_SCRAPE_BROCHURE_HUB=true

# Optional: require X-Admin-Key header on KB write endpoints (upload, delete, reindex)
ADMIN_API_KEY=

# Extra Groq call after each reply — keep false for fastest responses
FAITHFULNESS_ENABLED=false
FAITHFULNESS_MODEL=llama-3.1-8b-instant

# Policy Audit Evaluator (Audit mode)
AUDIT_EXTRACTION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AUDIT_ANALYSIS_MODEL=openai/gpt-oss-20b
AUDIT_CHAT_MODEL=llama-3.3-70b-versatile
AUDIT_MAX_TOKENS_EXTRACT=1024
AUDIT_MAX_TOKENS_VERDICT=1536
AUDIT_MAX_TOKENS_GEO=512
AUDIT_MAX_TOKENS_COMPARE=2048
AUDIT_CONTEXT_CHARS=12000
