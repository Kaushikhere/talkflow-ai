GROQ_API_KEY=your_groq_api_key_here
# Fast default; use llama-3.3-70b-versatile only if you need higher quality (slower)
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=1536

KB_ENABLED=true
KB_TOP_K=10
KB_RETRIEVE_POOL=20
KB_RERANK_POOL=16
KB_RERANK_ENABLED=true
# Fast default (CPU-friendly). For higher retrieval quality (slower): BAAI/bge-reranker-base
KB_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
KB_RERANK_MAX_CHARS=512
KB_RERANK_BATCH_SIZE=32
KB_CHUNK_SIZE=800
KB_CHUNK_MIN_CHARS=50
KB_CHUNK_FILTER_ENABLED=true

# Scrape settings (CLI / POST /kb/ingest/external with no_scrape=false)
KB_SEED_URLS=
KB_MAX_PDFS=0
KB_SCRAPE_DELAY_SEC=0.8
KB_SCRAPE_MAX_DEPTH=2
KB_SCRAPE_MAX_PAGES=40
KB_SCRAPE_PRODUCT_PAGES=true
KB_SCRAPE_BROCHURE_HUB=true

# Optional: require X-Admin-Key header on KB write endpoints (upload, delete, reindex)
ADMIN_API_KEY=

# Extra Groq call after each reply — keep false for fastest responses
FAITHFULNESS_ENABLED=false
FAITHFULNESS_MODEL=llama-3.1-8b-instant
